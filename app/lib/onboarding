// Helper to get total step count
export const totalSteps = onboardingQuiz.length;

// Helper to get step by index
export function getStep(stepIndex: number): QuizStep | undefined {
  return onboardingQuiz[stepIndex];
}

// Helper to get step by ID
export function getStepById(stepId: string): QuizStep | undefined {
  return onboardingQuiz.find((step) => step.id === stepId);
}

// Type for collected answers
export interface OnboardingAnswers {
  name?: string;
  style_personalities?: string[];
  lifestyle_contexts?: string[];
  dress_code?: string;
  desired_feelings?: string[];
  current_confidence?: number;
  style_struggles?: string[];
  favorite_colors?: string[];
  avoid_colors?: string[];
  top_size?: string;
  bottom_size?: string;
  shoe_size?: string;
  fit_preference?: string;
  body_areas_highlight?: string[];
  body_areas_minimize?: string[];
  help_priorities?: string[];
  additional_info?: string;
}

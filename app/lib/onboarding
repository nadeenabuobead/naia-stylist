// Complete quiz data structure for nAia onboarding

export type QuestionType =
  | "single-select"
  | "multi-select"
  | "image-grid"
  | "open-text"
  | "color-picker"
  | "scale";

export interface QuizOption {
  value: string;
  label: string;
  description?: string;
  icon?: string;
  imageUrl?: string;
  hex?: string;
}

export interface QuizQuestion {
  id: string;
  type: QuestionType;
  question: string;
  description?: string;
  options?: QuizOption[];
  placeholder?: string;
  minSelect?: number;
  maxSelect?: number;
  min?: number;
  max?: number;
  lowLabel?: string;
  highLabel?: string;
  required?: boolean;
}

export interface QuizStep {
  id: string;
  title: string;
  subtitle?: string;
  questions: QuizQuestion[];
}


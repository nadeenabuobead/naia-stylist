        {/* Daily Quote with header */}
        <div style={{ background: "linear-gradient(135deg, rgba(139,32,53,0.05) 0%, rgba(139,32,53,0.02) 100%)", padding: "32px 40px", marginBottom: "40px", border: "1px solid rgba(139,32,53,0.08)" }}>
          <div style={{ fontFamily: "'Space Mono',monospace", fontSize: "7px", letterSpacing: "2px", textTransform: "uppercase", color: "#8b2035", marginBottom: "12px", textAlign: "center" }}>TODAY'S VIBE</div>
          <div style={{ fontFamily: "'Playfair Display',serif", fontSize: "24px", fontStyle: "italic", lineHeight: 1.6, color: "#221516", textAlign: "center" }}>
            "{insights.dailyQuote}"
          </div>
        </div>

        {/* Stats */}
        <div style={{ display: "grid", gridTemplateColumns: "repeat(4,1fr)", gap: "16px", marginBottom: "40px" }}>
          <div style={{ background: "rgba(255,255,255,0.5)", padding: "24px", border: "1px solid rgba(59,5,16,0.06)" }}>
            <div style={{ fontFamily: "'Playfair Display',serif", fontSize: "48px", fontWeight: 900 }}>{stats.looksStyled}</div>
            <div style={{ fontFamily: "'Space Mono',monospace", fontSize: "7px", letterSpacing: "2px", textTransform: "uppercase", color: "#7a6f6a" }}>LOOKS STYLED</div>
          </div>
          <div style={{ background: "rgba(255,255,255,0.5)", padding: "24px", border: "1px solid rgba(59,5,16,0.06)" }}>
            <div style={{ fontFamily: "'Playfair Display',serif", fontSize: "48px", fontWeight: 900 }}>{stats.closetPieces}</div>
            <div style={{ fontFamily: "'Space Mono',monospace", fontSize: "7px", letterSpacing: "2px", textTransform: "uppercase", color: "#7a6f6a" }}>WARDROBE PIECES</div>
          </div>
          <div style={{ background: "rgba(255,255,255,0.5)", padding: "24px", border: "1px solid rgba(59,5,16,0.06)" }}>
            <div style={{ fontFamily: "'Playfair Display',serif", fontSize: "48px", fontWeight: 900 }}>{stats.avgRating}</div>
            <div style={{ fontFamily: "'Space Mono',monospace", fontSize: "7px", letterSpacing: "2px", textTransform: "uppercase", color: "#7a6f6a" }}>AVG CONFIDENCE</div>
          </div>
          <div style={{ background: "rgba(255,255,255,0.5)", padding: "24px", border: "1px solid rgba(59,5,16,0.06)" }}>
            <div style={{ fontFamily: "'Playfair Display',serif", fontSize: "48px", fontWeight: 900 }}>{stats.styleAlignment}</div>
            <div style={{ fontFamily: "'Space Mono',monospace", fontSize: "7px", letterSpacing: "2px", textTransform: "uppercase", color: "#7a6f6a" }}>STYLE ALIGNMENT</div>
          </div>
        </div>

        {/* Styling Identity */}
        <div style={{ background: "rgba(255,255,255,0.5)", padding: "28px 36px", marginBottom: "60px", border: "1px solid rgba(59,5,16,0.06)", textAlign: "center" }}>

            <div style={{ fontSize: "32px", marginBottom: "16px", opacity: 0.3 }}>◼</div>
            <h3 style={{ fontFamily: "'Playfair Display',serif", fontSize: "24px", fontWeight: 700, marginBottom: "8px", color: "#221516" }}>Digital Wardrobe</h3>
            <p style={{ fontFamily: "'Cormorant Garamond',serif", fontSize: "15px", fontStyle: "italic", color: "#7a6f6a" }}>Upload, save, and style your pieces with nAia.</p>
          </Link>
          <a href="https://naiabynadine.com/pages/buy-or-skip" style={{ background: "#221516", color: "#f4f4f1", padding: "32px", border: "1px solid rgba(59,5,16,0.06)", minHeight: "180px", textDecoration: "none", display: "block" }}>
            <div style={{ fontSize: "32px", marginBottom: "16px", opacity: 0.3 }}>◇</div>
            <h3 style={{ fontFamily: "'Playfair Display',serif", fontSize: "24px", fontWeight: 700, marginBottom: "8px" }}>Buy or Skip</h3>
            <p style={{ fontFamily: "'Cormorant Garamond',serif", fontSize: "15px", fontStyle: "italic", color: "#e1dbd7" }}>Upload a piece. nAia tells you if it belongs.</p>
          </a>
          <div style={{ background: "rgba(255,255,255,0.5)", padding: "32px", border: "1px solid rgba(59,5,16,0.06)", minHeight: "180px", opacity: 0.5 }}>
            <div style={{ fontSize: "32px", marginBottom: "16px", opacity: 0.3 }}>★</div>
            <h3 style={{ fontFamily: "'Playfair Display',serif", fontSize: "24px", fontWeight: 700, marginBottom: "8px" }}>Wardrobe Intelligence</h3>

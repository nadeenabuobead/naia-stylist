generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

// ─── Shopify admin session (existing — for the embedded app dashboard) ───
model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// ─── Customer (storefront shopper) ───
model Customer {
  id              String          @id @default(cuid())
  shopifyId       String          @unique
  email           String?
  firstName       String?
  lastName        String?
  lastMood        String?
  lastFeeling     String?
  lastEvent       String?
  lastStyleWords  String?
  lastBodyPref    String?
  lastMode        String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  closetItems     ClosetItem[]
  wishlistItems   WishlistItem[]
  outfitHistories OutfitHistory[]
  outfitRatings   OutfitRating[]
}

// ─── Closet pieces (what the customer owns) ───
model ClosetItem {
  id         String   @id @default(cuid())
  customerId String
  name       String
  category   String
  image      String?  @db.Text
  createdAt  DateTime @default(now())

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

// ─── Wishlist (nAia pieces the customer wants) ───
model WishlistItem {
  id             String   @id @default(cuid())
  customerId     String
  naiaProductId  String
  title          String
  handle         String
  image          String?
  createdAt      DateTime @default(now())

  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, naiaProductId])
  @@index([customerId])
}

// ─── Outfit history (past styling results) ───
model OutfitHistory {
  id            String   @id @default(cuid())
  customerId    String
  mood          String?
  feeling       String?
  event         String?
  styleWords    String?
  bodyPref      String?
  mode          String?
  closetItemIds String?
  result        String   @db.Text
  createdAt     DateTime @default(now())

  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  rating        OutfitRating?

  @@index([customerId])
  @@index([customerId, createdAt(sort: Desc)])
}

// ─── Outfit confidence rating ───
model OutfitRating {
  id                    String   @id @default(cuid())
  customerId            String
  historyId             String
  confidence            Int                          // 1-5 scale
  feltLikeMe            Boolean?
  wouldWearAgain        Boolean?
  physicallyComfortable Boolean?
  mood                  String?                      // copied from outfit for easier aggregation
  feeling               String?
  event                 String?
  styleWords            String?
  createdAt             DateTime @default(now())

  customer              Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  history               OutfitHistory @relation(fields: [historyId], references: [id], onDelete: Cascade)

  @@unique([customerId, historyId])
  @@index([customerId])
  @@index([customerId, confidence])
}


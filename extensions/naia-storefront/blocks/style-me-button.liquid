<div id="naia-style-me-button"></div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const button = document.createElement('a');
    button.href = '#';
    button.innerText = 'Style Me';
    button.style.cssText = 'position:fixed;bottom:28px;right:28px;background:#221516;color:#f4f4f1;padding:14px 32px;border-radius:999px;font-size:15px;font-weight:600;text-decoration:none;z-index:9999;box-shadow:0 4px 20px rgba(0,0,0,0.2);font-family:Space Mono,monospace;cursor:pointer;text-transform:uppercase;letter-spacing:2px;';
    
    button.addEventListener('click', function(e) {
      e.preventDefault();
      window.location.href = 'https://naia-stylist.vercel.app/quick-style';
    });
    
    document.body.appendChild(button);
  });
</script>

{% schema %}
{
  "name": "nAia Style Me Button",
  "target": "section",
  "settings": []
}
{% endschema %}
